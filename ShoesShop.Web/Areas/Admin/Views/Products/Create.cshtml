@{ ViewData["Title"] = "Thêm sản phẩm"; }

<div class="page-header d-flex justify-content-between align-items-center">
    <div><h3><i class="bi bi-plus-circle me-2 text-primary"></i>Thêm sản phẩm mới</h3></div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-3"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <partial name="_ProductForm" />
    <div class="mt-4 d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-light rounded-3 px-4">Hủy</a>
        <button type="submit" class="btn btn-primary rounded-3 px-4 shadow-sm"><i class="bi bi-check-lg me-1"></i>Tạo sản phẩm</button>
    </div>
</form>
