<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - STRIDEX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="site-navbar navbar navbar-expand-lg">
    <div class="container-xxl px-4">

        <!-- Logo -->
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
            STRIDEX
        </a>

        <!-- Toggler -->
        <button class="navbar-toggler border-0 p-1" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false">
            <i class="bi bi-list text-white fs-4"></i>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <!-- Main links -->
            <ul class="navbar-nav mx-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")"
                       asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Products"?"active":"")"
                       asp-area="" asp-controller="Products" asp-action="Index">Sản phẩm</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Products" asp-action="Index"
                       asp-route-gender="Men">Nam</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Products" asp-action="Index"
                       asp-route-gender="Women">Nữ</a>
                </li>
            </ul>

            <!-- Right actions -->
            <div class="d-flex align-items-center gap-2">

                <!-- Search -->
                <form class="nav-search d-none d-lg-block"
                      asp-area="" asp-controller="Products" asp-action="Index" method="get">
                    <input type="text" name="q" placeholder="Tìm kiếm..." />
                    <button type="submit" class="search-btn"><i class="bi bi-search"></i></button>
                </form>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- Orders shortcut (Customer only) -->
                    @if (User.IsInRole("Customer"))
                    {
                        <a asp-controller="Orders" asp-action="Index" class="nav-icon-btn" title="Đơn hàng">
                            <i class="bi bi-bag"></i>
                        </a>
                    }

                    <!-- Admin/Staff panel -->
                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                    {
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                           class="nav-icon-btn" title="Quản trị">
                            <i class="bi bi-grid"></i>
                        </a>
                    }
                }

                <!-- Cart -->
                <a asp-controller="Cart" asp-action="Index" class="nav-icon-btn" title="Giỏ hàng"
                   id="cart-nav-btn" style="position:relative">
                    <i class="bi bi-bag-fill"></i>
                    <span class="cart-badge" id="cart-count" style="display:none">0</span>
                </a>

                <!-- User menu -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown">
                        <button class="nav-icon-btn dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-person"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">@User.Identity.Name</h6></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle me-2"></i>Tài khoản của tôi
                                </a>
                            </li>
                            @if (User.IsInRole("Customer"))
                            {
                                <li>
                                    <a class="dropdown-item" asp-controller="Orders" asp-action="Index">
                                        <i class="bi bi-bag-check me-2"></i>Đơn hàng của tôi
                                    </a>
                                </li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item" style="color:#e63946">
                                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login"
                       class="btn-white" style="padding:8px 18px;font-size:0.75rem;">Đăng nhập</a>
                }
            </div>
        </div>
    </div>
</nav>

<!-- ── ALERTS ── -->
@if (TempData["Success"] != null)
{
    <div class="alert-bar success d-flex align-items-center gap-2" id="toast-success">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <span>@TempData["Success"]</span>
        <button class="btn-close btn-close-sm ms-auto" onclick="this.parentElement.remove()"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-bar danger d-flex align-items-center gap-2" id="toast-error">
        <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
        <span>@TempData["Error"]</span>
        <button class="btn-close btn-close-sm ms-auto" onclick="this.parentElement.remove()"></button>
    </div>
}

<!-- ── MAIN ── -->
<main>
    @RenderBody()
</main>

<!-- ── FOOTER ── -->
<footer class="site-footer">
    <div class="container-xxl px-4">
        <div class="row g-5">
            <div class="col-lg-4 col-md-6">
                <div class="footer-logo mb-16">STRIDEX</div>
                <p style="font-size:0.85rem;max-width:280px;margin-top:12px;line-height:1.7;">
                    Giày thể thao chính hãng, phong cách hiện đại. Đặt hàng trực tuyến, giao nhanh toàn quốc.
                </p>
                <div class="d-flex gap-3 mt-24">
                    <a href="#" style="color:rgba(255,255,255,0.5);font-size:1.2rem;display:inline"><i class="bi bi-facebook"></i></a>
                    <a href="#" style="color:rgba(255,255,255,0.5);font-size:1.2rem;display:inline"><i class="bi bi-instagram"></i></a>
                    <a href="#" style="color:rgba(255,255,255,0.5);font-size:1.2rem;display:inline"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>
            <div class="col-lg-2 col-md-6">
                <h5>Sản phẩm</h5>
                <a asp-area="" asp-controller="Products" asp-action="Index" asp-route-gender="Men">Giày Nam</a>
                <a asp-area="" asp-controller="Products" asp-action="Index" asp-route-gender="Women">Giày Nữ</a>
                <a asp-area="" asp-controller="Products" asp-action="Index" asp-route-gender="Unisex">Unisex</a>
                <a asp-area="" asp-controller="Products" asp-action="Index">Tất cả sản phẩm</a>
            </div>
            <div class="col-lg-2 col-md-6">
                <h5>Hỗ trợ</h5>
                <a href="#">Hướng dẫn chọn size</a>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Chính sách bảo hành</a>
                <a href="#">Liên hệ</a>
            </div>
            <div class="col-lg-4 col-md-6">
                <h5>Đăng ký nhận ưu đãi</h5>
                <p style="font-size:0.82rem;margin-bottom:14px;">Nhập email để nhận thông tin khuyến mãi độc quyền.</p>
                <div class="d-flex" style="border:1px solid rgba(255,255,255,0.2);">
                    <input type="email" placeholder="your@email.com" class="form-control border-0 bg-transparent text-white" style="font-size:0.82rem;padding:10px 14px;" />
                    <button class="btn-black px-4" style="border-radius:0;white-space:nowrap;font-size:0.72rem;">Đăng ký</button>
                </div>
            </div>
        </div>
        <div class="footer-bottom d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>&copy; 2026 STRIDEX. All rights reserved.</span>
            <span>Designed for FPTU PRN232 Final Project</span>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    // Update cart badge
    function updateCartBadge() {
        const cart = JSON.parse(localStorage.getItem('shoes_shop_cart')) || [];
        const total = cart.reduce((s, i) => s + i.quantity, 0);
        const badge = document.getElementById('cart-count');
        if (badge) {
            badge.textContent = total;
            badge.style.display = total > 0 ? 'flex' : 'none';
        }
    }
    updateCartBadge();
    window.addEventListener('storage', updateCartBadge);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>