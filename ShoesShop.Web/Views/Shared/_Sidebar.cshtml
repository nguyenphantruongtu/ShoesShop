@* Reusable vertical sidebar for admin/dashboard pages *@
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLowerInvariant();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString()?.ToLowerInvariant();
}

<nav lang="vi" class="d-flex flex-column bg-white border rounded p-3 h-100" style="min-width:220px;">
    <div class="mb-3">
        <h6 class="mb-0 fw-bold">Quản trị</h6>
        <small class="text-muted">Điều hướng</small>
    </div>

    <ul class="nav nav-pills flex-column">
        <li class="nav-item mb-1">
            <a class="nav-link d-flex align-items-center justify-content-between @((currentController == "dashboard") ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                <span><i class="bi bi-speedometer2 me-2" aria-hidden="true"></i>Dashboard</span>
            </a>
        </li>

        <li class="nav-item mb-1">
            <a class="nav-link d-flex align-items-center justify-content-between @((currentController == "reports") ? "active" : "")" href="#reportsSubmenu" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="reportsSubmenu">
                <span><i class="bi bi-graph-up me-2" aria-hidden="true"></i>Báo cáo</span>
                <i class="bi bi-chevron-down"></i>
            </a>
            <div class="collapse @(currentController == "reports" ? "show" : "")" id="reportsSubmenu">
                <ul class="nav flex-column ms-3 mt-2">
                    <li class="nav-item mb-1">
                        <a class="nav-link py-1 @((currentController == "reports" && currentAction == "topproducts") ? "active" : "")" asp-controller="Reports" asp-action="TopProducts">Top sản phẩm bán chạy</a>
                    </li>
                    <li class="nav-item mb-1">
                        <a class="nav-link py-1 @((currentController == "reports" && currentAction == "bybrand") ? "active" : "")" asp-controller="Reports" asp-action="ByBrand">Doanh thu theo thương hiệu</a>
                    </li>
                    <li class="nav-item mb-1">
                        <a class="nav-link py-1 @((currentController == "reports" && currentAction == "bycategory") ? "active" : "")" asp-controller="Reports" asp-action="ByCategory">Doanh thu theo danh mục</a>
                    </li>
                </ul>
            </div>
        </li>
    </ul>

    <div class="mt-auto pt-3 border-top">
        <small class="text-muted">Phiên bản UI 1.0</small>
    </div>
</nav>