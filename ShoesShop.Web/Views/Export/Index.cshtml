@model ShoesShop.Web.Models.ExportViewModel

@{
    ViewData["Title"] = "Export CSV";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_Sidebar")
        </div>
        <div class="col-md-9">
            <div class="card p-4 shadow-sm border-0">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="bi bi-file-earmark-spreadsheet fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">Export CSV</h4>
                        <small class="text-muted">Xuất dữ liệu hệ thống ra file CSV (Excel/PDF là stretch goal)</small>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
                }

                <form asp-action="Download" method="post" id="exportForm">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="SelectedType">Loại dữ liệu</label>
                        <select asp-for="SelectedType" class="form-select" id="SelectedType">
                            @foreach (var type in Model.ExportTypes)
                            {
                                <option value="@type.Key"
                                        data-supports-date="@type.SupportsDateRange.ToString().ToLowerInvariant()"
                                        data-supports-top="@type.SupportsTop.ToString().ToLowerInvariant()">
                                    @type.Label
                                </option>
                            }
                        </select>
                    </div>

                    <div id="dateRangeGroup" class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="From" class="form-label fw-semibold">Từ ngày</label>
                            <input asp-for="From" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="To" class="form-label fw-semibold">Đến ngày</label>
                            <input asp-for="To" type="date" class="form-control" />
                        </div>
                    </div>

                    <div id="topGroup" class="mb-4">
                        <label asp-for="Top" class="form-label fw-semibold">Số bản ghi top</label>
                        <input asp-for="Top" type="number" min="1" max="100" class="form-control" style="max-width: 180px;" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-download me-1"></i> Tải file CSV
                        </button>
                    </div>
                </form>

                <hr class="my-4" />

                <div class="small text-muted">
                    <div class="fw-semibold mb-2">Gợi ý</div>
                    <ul class="mb-0">
                        <li>File CSV dùng UTF-16 (Unicode) để Excel Windows hiển thị tiếng Việt đúng.</li>
                        <li>Đơn hàng và báo cáo có thể lọc theo khoảng thời gian.</li>
                        <li>Đảm bảo project <code>ShoesShop.API</code> đang chạy trước khi export.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var typeSelect = document.getElementById('SelectedType');
            var dateRangeGroup = document.getElementById('dateRangeGroup');
            var topGroup = document.getElementById('topGroup');

            function syncFields() {
                var option = typeSelect.options[typeSelect.selectedIndex];
                var supportsDate = option.dataset.supportsDate === 'true';
                var supportsTop = option.dataset.supportsTop === 'true';

                dateRangeGroup.style.display = supportsDate ? '' : 'none';
                topGroup.style.display = supportsTop ? '' : 'none';
            }

            typeSelect.addEventListener('change', syncFields);
            syncFields();
        })();
    </script>
}
