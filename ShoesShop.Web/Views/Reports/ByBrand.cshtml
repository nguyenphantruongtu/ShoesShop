@model IEnumerable<ShoesShop.Shared.DTOs.RevenueGroupDto>

@{
    ViewData["Title"] = "Doanh thu theo thương hiệu";
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_Sidebar")
        </div>
        <div class="col-md-9">
            <div class="card p-3">
                <h4 class="mb-3">Doanh thu theo thương hiệu</h4>
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Thương hiệu</th>
                            <th>Số lượng</th>
                            <th>Doanh thu</th>
          
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var i = 1;
                            foreach (var row in Model)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>@row.GroupName</td>
                                    <td>@row.TotalQuantity</td>
                                    <td>@row.TotalRevenue.ToString("#,##0") đ</td>
                                </tr>
                                i++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">Không có dữ liệu</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
