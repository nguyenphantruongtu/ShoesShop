@{
    ViewData["Title"] = "Sản phẩm — STRIDEX";
    string initQ = Context.Request.Query["q"].ToString();
}

<div class="container-xxl px-4 py-5">

    <!-- ── Page header ── -->
    <div class="mb-5">
        <span class="section-eyebrow">Cửa hàng</span>
        <h1 class="section-title mb-0">Tất cả sản phẩm</h1>
    </div>

    <div class="row g-5">

        <!-- ═══ SIDEBAR FILTER ═══ -->
        <div class="col-lg-2 col-md-3">
            <div class="filter-sidebar">

                <!-- Search -->
                <div class="filter-group" style="padding-top:0">
                    <div class="filter-title" style="margin-bottom:10px">Tìm kiếm</div>
                    <div style="position:relative">
                        <input type="text" id="searchInput" value="@initQ"
                               placeholder="Nhập tên giày..."
                               class="form-control-clean"
                               style="padding-right:36px">
                        <i class="bi bi-search"
                           style="position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#888;font-size:0.82rem"></i>
                    </div>
                </div>

                <!-- Price -->
                <div class="filter-group">
                    <div class="filter-title">Khoảng giá</div>
                    @foreach (var p in new[] { ("","Tất cả"), ("500000","Dưới 500K"), ("1000000","Dưới 1 triệu"), ("2000000","Dưới 2 triệu"), ("5000000","Dưới 5 triệu") })
                    {
                        <label class="filter-option">
                            <input type="radio" name="price" value="@p.Item1"
                                   @(p.Item1 == "" ? "checked" : "")
                                   onchange="resetAndLoad()">
                            @p.Item2
                        </label>
                    }
                </div>

                <!-- Sort -->
                <div class="filter-group">
                    <div class="filter-title">Sắp xếp</div>
                    <select id="sortSelect" class="form-control-clean" onchange="resetAndLoad()" style="cursor:pointer">
                        <option value="ProductId desc">Mới nhất</option>
                        <option value="BasePrice asc">Giá thấp → cao</option>
                        <option value="BasePrice desc">Giá cao → thấp</option>
                        <option value="ProductName asc">Tên A → Z</option>
                    </select>
                </div>

                <!-- Reset -->
                <button onclick="resetFilters()" class="btn-white w-100 mt-2" style="font-size:0.75rem;padding:9px 0;">
                    <i class="bi bi-x-circle me-1"></i>Xóa bộ lọc
                </button>
            </div>
        </div>

        <!-- ═══ PRODUCT GRID ═══ -->
        <div class="col-lg-10 col-md-9">

            <!-- Active filters bar -->
            <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
                <div id="activeFilters" class="d-flex gap-2 flex-wrap"></div>
                <span id="resultCount" style="font-size:0.8rem;color:#888"></span>
            </div>

            <!-- Loading -->
            <div id="loading" class="text-center py-5">
                <div class="spinner-border" role="status" style="width:28px;height:28px;border-width:2px"></div>
                <p style="font-size:0.82rem;color:#888;margin-top:10px">Đang tải sản phẩm...</p>
            </div>

            <!-- Grid -->
            <div id="productGrid" class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-3 d-none"></div>

            <!-- Empty -->
            <div id="emptyState" class="text-center py-5 d-none">
                <i class="bi bi-search" style="font-size:3rem;color:#ddd"></i>
                <p style="margin-top:16px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;font-size:0.88rem">Không tìm thấy sản phẩm</p>
                <p style="font-size:0.82rem;color:#888">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
            </div>

            <!-- Pagination -->
            <div id="paginationWrap" class="d-flex justify-content-center mt-5 d-none">
                <ul class="pagination pagination-clean" id="pagination"></ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const API_BASE = 'https://localhost:7214';
const PAGE_SIZE = 12;
let currentPage = 0;

$(document).ready(function() {
    // auto-search on type (debounced)
    let timer;
    $('#searchInput').on('input', function() {
        clearTimeout(timer);
        timer = setTimeout(() => { currentPage = 0; loadProducts(); }, 380);
    });
    loadProducts();
});

function resetAndLoad() { currentPage = 0; loadProducts(); }

function resetFilters() {
    $('input[name="price"]').first().prop('checked', true);
    $('#sortSelect').val('ProductId desc');
    $('#searchInput').val('');
    resetAndLoad();
}

function loadProducts() {
    const maxPrice = $('input[name="price"]:checked').val();
    const sort     = $('#sortSelect').val();
    const q        = $('#searchInput').val().trim();

    let url = `${API_BASE}/api/products?$top=${PAGE_SIZE}&$skip=${currentPage * PAGE_SIZE}&$count=true`;

    let filters = [];
    if (maxPrice) filters.push(`BasePrice le ${maxPrice}`);
    if (filters.length) url += `&$filter=${filters.join(' and ')}`;
    if (sort)     url += `&$orderby=${sort}`;

    // Update active filters display
    updateActiveFilters(maxPrice, q);

    $('#loading').show();
    $('#productGrid, #emptyState, #paginationWrap').addClass('d-none');

    // If search query, use search endpoint then filter client-side
    const fetchUrl = q
        ? `${API_BASE}/api/products/search?keyword=${encodeURIComponent(q)}`
        : url;

    $.ajax({
        url: fetchUrl,
        type: 'GET',
        success: function(res) {
            let products = [];
            let total = 0;
            if (res && res.value !== undefined) { products = res.value; total = res['@@odata.count'] || products.length; }
            else if (res && res.success && Array.isArray(res.data)) { products = res.data; total = products.length; }
            else if (Array.isArray(res)) { products = res; total = products.length; }

            $('#loading').hide();
            $('#resultCount').text(total ? `${total} sản phẩm` : '');

            if (!products.length) {
                $('#emptyState').removeClass('d-none');
                return;
            }
            renderGrid(products);
            if (!q) renderPagination(total);
        },
        error: function() {
            $('#loading').hide();
            $('#emptyState').removeClass('d-none');
        }
    });
}

function renderGrid(products) {
    let html = '';
    products.forEach(p => {
        const id      = p.productId || p.ProductId;
        const name    = p.productName || p.ProductName || '';
        const base    = p.basePrice || p.BasePrice || 0;
        const sale    = p.salePrice || p.SalePrice;
        const hasSale = sale && sale < base;
        const price   = hasSale ? sale : base;
        const salePct = hasSale ? Math.round((1 - sale/base)*100) : 0;
        const imgs    = p.imageUrls || p.ImageUrls || [];
        const img     = imgs.length ? imgs[0] : 'https://placehold.co/400x400/f3f3f3/888?text=No+Image';
        const brand   = p.brandName || p.BrandName || 'Sneaker';
        const url     = '/Products/Detail/' + id;

        html += `
        <div class="col">
            <div class="product-card">
                <div class="product-card-img-wrap">
                    ${hasSale ? `<span class="product-badge product-badge-sale">-${salePct}%</span>` : ''}
                    <img src="${img}" alt="${name}" loading="lazy"
                         onerror="this.src='https://placehold.co/400x400/f3f3f3/888?text=No+Image'">
                    <div class="product-card-overlay">
                        <a href="${url}" class="product-card-quick-btn">Xem chi tiết</a>
                    </div>
                </div>
                <div class="product-card-body px-1">
                    <div class="product-card-category">${brand}</div>
                    <div class="product-card-name"><a href="${url}" style="color:#000">${name}</a></div>
                    <div class="product-card-price">
                        ${hasSale
                            ? `<span class="sale">${price.toLocaleString('vi-VN')}₫</span><span class="original">${base.toLocaleString('vi-VN')}₫</span>`
                            : `${price.toLocaleString('vi-VN')}₫`
                        }
                    </div>
                </div>
            </div>
        </div>`;
    });
    $('#productGrid').html(html).removeClass('d-none');
}

function renderPagination(total) {
    const pages = Math.ceil(total / PAGE_SIZE);
    if (pages <= 1) { $('#paginationWrap').addClass('d-none'); return; }
    let html = `<li class="page-item ${currentPage===0?'disabled':''}">
        <a class="page-link" href="#" onclick="changePage(${currentPage-1}); return false;">‹</a></li>`;
    for (let i = 0; i < pages; i++) {
        html += `<li class="page-item ${i===currentPage?'active':''}">
            <a class="page-link" href="#" onclick="changePage(${i}); return false;">${i+1}</a></li>`;
    }
    html += `<li class="page-item ${currentPage===pages-1?'disabled':''}">
        <a class="page-link" href="#" onclick="changePage(${currentPage+1}); return false;">›</a></li>`;
    $('#pagination').html(html);
    $('#paginationWrap').removeClass('d-none');
}

function changePage(p) {
    currentPage = p;
    loadProducts();
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function updateActiveFilters(maxPrice, q) {
    let chips = '';
    if (maxPrice) chips += `<span class="filter-chip active">Dưới ${(+maxPrice).toLocaleString('vi-VN')}₫ <i class="bi bi-x" onclick="clearFilter('price')"></i></span>`;
    if (q)        chips += `<span class="filter-chip active">"${q}" <i class="bi bi-x" onclick="clearSearch()"></i></span>`;
    $('#activeFilters').html(chips);
}

function clearFilter(name) {
    $(`input[name="${name}"]`).first().prop('checked', true);
    resetAndLoad();
}
function clearSearch() { $('#searchInput').val(''); resetAndLoad(); }
</script>
}
