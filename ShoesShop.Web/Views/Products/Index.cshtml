@{
    ViewData["Title"] = "Cửa Hàng - Shoes Shop";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0">
                <h5 class="font-weight-bold mb-3">BỘ LỌC SẢN PHẨM</h5>

                <div class="mb-3">
                    <label class="form-label font-weight-bold text-secondary">Giới tính</label>
                    <select id="filterGender" class="form-select form-control" onchange="resetAndLoad()">
                        <option value="">Tất cả</option>
                        <option value="Men">Nam</option>
                        <option value="Women">Nữ</option>
                        <option value="Unisex">Unisex</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold text-secondary">Khoảng Giá (Đến)</label>
                    <select id="filterPrice" class="form-select form-control" onchange="resetAndLoad()">
                        <option value="">Tất cả mức giá</option>
                        <option value="1000000">Dưới 1,000,000 đ</option>
                        <option value="2000000">Dưới 2,000,000 đ</option>
                        <option value="5000000">Dưới 5,000,000 đ</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label font-weight-bold text-secondary">Sắp xếp theo</label>
                    <select id="sortOrder" class="form-select form-control" onchange="resetAndLoad()">
                        <option value="ProductName asc">Tên: A -> Z</option>
                        <option value="BasePrice asc">Giá: Thấp đến Cao</option>
                        <option value="BasePrice desc">Giá: Cao đến Thấp</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="row" id="productContainer">
            </div>

            <div class="d-flex justify-content-center mt-4">
                <nav>
                    <ul class="pagination" id="paginationContainer">
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let pageSize = 6;
        let currentPage = 0;

        $(document).ready(function () {
            loadProducts();
        });

        function resetAndLoad() {
            currentPage = 0;
            loadProducts();
        }

        function loadProducts() {
            let gender = $("#filterGender").val();
            let maxPrice = $("#filterPrice").val();
            let sort = $("#sortOrder").val();

            // Đường dẫn gọi OData Controller chuẩn chỉnh
            let odataUrl = `https://localhost:7214/api/products?$top=${pageSize}&$skip=${currentPage * pageSize}&$count=true`;

            let filters = [];

            if (gender) {
                // Viết Hoa chữ cái đầu theo chuẩn thuộc tính Entity Model DTO
                filters.push(`Gender eq '${gender}'`);
            }
            if (maxPrice) {
                // Viết Hoa chữ cái đầu theo chuẩn thuộc tính Entity Model DTO
                filters.push(`BasePrice le ${maxPrice}`);
            }

            if (filters.length > 0) {
                odataUrl += `&$filter=${filters.join(' and ')}`;
            }

            if (sort) {
                odataUrl += `&$orderby=${sort}`;
            }

            console.log("Đang gọi API tại URL: ", odataUrl);

            $.ajax({
                url: odataUrl,
                type: "GET",
                dataType: "json",
                success: function (response) {
                    console.log("Dữ liệu thô OData trả về:", response);

                    let products = [];
                    let totalCount = 0;

                    // Bóc tách chính xác gói dữ liệu chuẩn OData v4
                    if (response && response.value !== undefined) {
                        products = response.value;
                        totalCount = response["@@odata.count"] || products.length; // Sửa ký tự bọc @@ cho Razor view không hiểu nhầm
                    } else if (Array.isArray(response)) {
                        products = response;
                        totalCount = response.length;
                    }

                    renderProducts(products);
                    renderPagination(totalCount);
                },
                error: function (xhr, status, error) {
                    console.error("Lỗi hệ thống AJAX:", xhr);

                    let errorMsg = "Không thể lấy dữ liệu từ API (Mã lỗi: " + xhr.status + ").";
                    if(xhr.responseJSON && xhr.responseJSON.error) {
                        errorMsg += "<br/><small class='text-muted'>Chi tiết: " + xhr.responseJSON.error.message + "</small>";
                    } else if (xhr.responseText) {
                        errorMsg += "<br/><small class='text-muted text-break text-wrap'>Phản hồi hệ thống: " + xhr.responseText.substring(0, 200) + "...</small>";
                    }

                    $("#productContainer").html(`<div class="col-12 text-center text-danger py-5">${errorMsg}</div>`);
                }
            });
        }

        function renderProducts(products) {
            let html = "";

            if (!products || products.length === 0) {
                $("#productContainer").html('<div class="col-12 text-center text-muted py-5">Không tìm thấy sản phẩm nào khớp với bộ lọc.</div>');
                $("#paginationContainer").html("");
                return;
            }

            products.forEach(p => {
                let id = p.productId || p.ProductId || p.id || p.Id;
                let name = p.productName || p.ProductName || "Sản phẩm không tên";
                let basePrice = p.basePrice || p.BasePrice || 0;
                let salePrice = p.salePrice || p.SalePrice || 0;
                let shortDesc = p.shortDescription || p.ShortDescription || "Đang cập nhật mô tả...";

                let imgUrl = "/images/no-image.png";
                let images = p.imageUrls || p.ImageUrls || p.productImages || p.ProductImages;

                if (images && images.length > 0) {
                    if (typeof images[0] === 'string') {
                        imgUrl = images[0];
                    } else if (images[0].imageUrl || images[0].ImageUrl) {
                        imgUrl = images[0].imageUrl || images[0].ImageUrl;
                    }
                }

                let priceHtml = "";
                if (salePrice && salePrice > 0) {
                    priceHtml = `
                        <span class="text-danger font-weight-bold">${salePrice.toLocaleString('vi-VN')} đ</span>
                        <del class="text-muted small ms-2">${basePrice.toLocaleString('vi-VN')} đ</del>
                    `;
                } else {
                    priceHtml = `<span class="text-danger font-weight-bold">${basePrice.toLocaleString('vi-VN')} đ</span>`;
                }

                html += `
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm border-0 rounded p-2">
                            <img src="${imgUrl}" class="card-img-top p-2" style="height: 220px; width: 100%; object-fit: cover; object-position: center;" alt="${name}">
                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <h6 class="card-title font-weight-bold text-dark mb-1" style="min-height: 40px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">${name}</h6>
                                    <p class="card-text text-muted small mb-2" style="display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">${shortDesc}</p>
                                </div>
                                <div>
                                    <div class="mb-3">
                                        ${priceHtml}
                                    </div>
                                    <a href="/products/detail/${id}" class="btn btn-sm btn-block btn-outline-primary rounded-pill w-100">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });

            $("#productContainer").html(html);
        }

        function renderPagination(totalCount) {
            let totalPages = Math.ceil(totalCount / pageSize);
            let html = "";

            if (totalPages <= 1) {
                $("#paginationContainer").html("");
                return;
            }

            html += `<li class="page-item ${currentPage === 0 ? 'disabled' : ''}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage - 1})">«</a>
                     </li>`;

            for (let i = 0; i < totalPages; i++) {
                html += `<li class="page-item ${currentPage === i ? 'active' : ''}">
                            <a class="page-link" href="javascript:void(0)" onclick="changePage(${i})">${i + 1}</a>
                         </li>`;
            }

            html += `<li class="page-item ${currentPage === totalPages - 1 ? 'disabled' : ''}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage + 1})">»</a>
                     </li>`;

            $("#paginationContainer").html(html);
        }

        function changePage(pageIndex) {
            currentPage = pageIndex;
            loadProducts();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
}