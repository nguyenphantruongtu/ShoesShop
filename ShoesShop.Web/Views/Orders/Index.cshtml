@using System.Text.Json
@model JsonElement?
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var statuses  = new[] { "Pending","Confirmed","Preparing","Shipping","Delivered","Cancelled" };
    var statusVi  = new Dictionary<string,string> { ["Pending"]="Chờ xác nhận",["Confirmed"]="Đã xác nhận",["Preparing"]="Đang chuẩn bị",["Shipping"]="Đang giao",["Delivered"]="Đã giao",["Cancelled"]="Đã hủy" };
    string curSt  = ViewBag.Status ?? "";
    int page      = ViewBag.Page ?? 1;
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1"><i class="bi bi-bag-check me-2 text-primary"></i>Đơn hàng của tôi</h2>
        <p class="text-muted">Theo dõi tình trạng và lịch sử mua hàng</p>
    </div>

    @* Status filter pills *@
    <div class="d-flex gap-2 flex-wrap mb-4 p-3 bg-white rounded-4 shadow-sm">
        <a asp-action="Index" class="btn btn-sm rounded-pill @(string.IsNullOrEmpty(curSt)?"btn-primary":"btn-outline-secondary")">Tất cả</a>
        @foreach (var s in statuses)
        {
            <a asp-action="Index" asp-route-status="@s" asp-route-page="1"
               class="btn btn-sm rounded-pill @(curSt==s?"btn-primary":"btn-outline-secondary")">@statusVi[s]</a>
        }
    </div>

    @if (Model is JsonElement data && data.ValueKind != JsonValueKind.Undefined)
    {
        var orders     = data.TryGetProperty("orders", out var o) ? o : data;
        var totalPages = data.TryGetProperty("totalPages", out var tp) ? tp.GetInt32() : 1;
        var total      = data.TryGetProperty("totalCount", out var tc) ? tc.GetInt32() : 0;

        if (orders.ValueKind == JsonValueKind.Array && orders.GetArrayLength() == 0)
        {
            <div class="card border-0 shadow-sm rounded-4 text-center py-5">
                <div class="py-3">
                    <i class="bi bi-bag-x display-4 text-muted opacity-50"></i>
                    <p class="text-muted mt-3 mb-0">Bạn chưa có đơn hàng nào@(string.IsNullOrEmpty(curSt) ? "" : " trong trạng thái này").</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary rounded-3 mt-3 px-4">
                        <i class="bi bi-bag me-2"></i>Mua sắm ngay
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
            @if (orders.ValueKind == JsonValueKind.Array)
                foreach (var ord in orders.EnumerateArray())
                {
                    var oid    = ord.GetProperty("orderId").GetInt32();
                    var code   = ord.GetProperty("orderCode").GetString();
                    var ostats = ord.GetProperty("orderStatus").GetString() ?? "";
                    var total2 = ord.GetProperty("totalAmount").GetDecimal();
                    var items  = ord.GetProperty("itemCount").GetInt32();
                    var date   = ord.GetProperty("createdAt").GetDateTime();
                    var badgeCls = ostats switch {
                        "Delivered"=>"bg-success","Shipping"=>"bg-info","Preparing"=>"bg-primary",
                        "Confirmed"=>"bg-primary bg-opacity-75","Cancelled"=>"bg-danger",_=>"bg-warning text-dark"
                    };
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <div class="fw-bold mb-1"><i class="bi bi-receipt me-2 text-muted"></i>@code</div>
                                    <div class="text-muted small">@date.ToString("HH:mm dd/MM/yyyy") &bull; @items sản phẩm</div>
                                </div>
                                <div class="text-end">
                                    <span class="badge rounded-pill px-3 @badgeCls mb-1">@(statusVi.GetValueOrDefault(ostats, ostats))</span>
                                    <div class="fw-bold text-primary">@total2.ToString("N0")₫</div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end mt-3">
                                <a asp-action="Detail" asp-route-id="@oid" class="btn btn-outline-primary btn-sm rounded-3 px-3">
                                    <i class="bi bi-eye me-1"></i>Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-4 d-flex justify-content-center"><ul class="pagination">
                    @for (int i = 1; i <= totalPages; i++)
                    { <li class="page-item @(i==page?"active":"")"><a class="page-link rounded-3 mx-1" asp-action="Index" asp-route-status="@curSt" asp-route-page="@i">@i</a></li> }
                </ul></nav>
            }
        }
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-exclamation-circle display-4 opacity-50"></i>
            <p class="mt-3">Không thể tải danh sách đơn hàng. Vui lòng thử lại.</p>
        </div>
    }
</div>
