@using System.Text.Json
@model JsonElement
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var orderId  = Model.GetProperty("orderId").GetInt32();
    var code     = Model.GetProperty("orderCode").GetString();
    var status   = Model.GetProperty("orderStatus").GetString() ?? "";
    var pStatus  = Model.GetProperty("paymentStatus").GetString() ?? "";
    var items    = Model.GetProperty("items");
    var history  = Model.TryGetProperty("statusHistory", out var h) ? h : default;
    var shipment = Model.TryGetProperty("shipment", out var sh) && sh.ValueKind != JsonValueKind.Null ? sh : (JsonElement?)null;
    var statusVi = new Dictionary<string,string>{["Pending"]="Chờ xác nhận",["Confirmed"]="Đã xác nhận",["Preparing"]="Đang chuẩn bị",["Shipping"]="Đang giao",["Delivered"]="Đã giao",["Cancelled"]="Đã hủy"};
    var badgeCls = status switch{"Delivered"=>"bg-success","Shipping"=>"bg-info","Preparing"=>"bg-primary","Confirmed"=>"bg-primary bg-opacity-75","Cancelled"=>"bg-danger",_=>"bg-warning text-dark"};
    bool canCancel  = status is "Pending" or "Confirmed";
    bool canReview  = status == "Delivered";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-receipt me-2 text-primary"></i>@code</h2>
            <span class="badge rounded-pill px-3 @badgeCls fs-6">@(statusVi.GetValueOrDefault(status, status))</span>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-3"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            @* Items *@
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-bag me-2 text-primary"></i>Sản phẩm đặt mua</h5>
                    @if (items.ValueKind == JsonValueKind.Array)
                    {
                        <div class="d-flex flex-column gap-3">
                        @foreach (var it in items.EnumerateArray())
                        {
                            var img  = it.TryGetProperty("primaryImageUrl", out var img2) && img2.ValueKind != JsonValueKind.Null ? img2.GetString() : null;
                            var pname= it.GetProperty("productName").GetString();
                            var size = it.GetProperty("sizeValue").GetString();
                            var color= it.GetProperty("colorName").GetString();
                            var qty  = it.GetProperty("quantity").GetInt32();
                            var price= it.GetProperty("unitPrice").GetDecimal();
                            var line = it.GetProperty("lineTotal").GetDecimal();
                            var reviewedField = it.TryGetProperty("isReviewed", out var rv) ? rv.GetBoolean() : false;
                            var oiid = it.GetProperty("orderItemId").GetInt32();
                            <div class="d-flex gap-3 align-items-center border rounded-4 p-3">
                                @if (!string.IsNullOrEmpty(img))
                                { <img src="@img" width="70" height="70" style="object-fit:cover" class="rounded-3 border"> }
                                else
                                { <div class="rounded-3 bg-light d-flex align-items-center justify-content-center flex-shrink-0" style="width:70px;height:70px"><i class="bi bi-image text-muted fs-4"></i></div> }
                                <div class="flex-grow-1">
                                    <div class="fw-bold">@pname</div>
                                    <div class="text-muted small">Size @size &bull; @color</div>
                                    <div class="text-muted small">@price.ToString("N0")₫ x @qty</div>
                                </div>
                                <div class="text-end flex-shrink-0">
                                    <div class="fw-bold text-primary">@line.ToString("N0")₫</div>
                                    @if (canReview && !reviewedField)
                                    {
                                        <button class="btn btn-sm btn-outline-warning rounded-3 mt-1"
                                                data-bs-toggle="modal" data-bs-target="#reviewModal"
                                                onclick="openReviewModal(@oiid,'@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(pname ?? "")')">
                                            <i class="bi bi-star me-1"></i>Đánh giá
                                        </button>
                                    }
                                    @if (canReview && reviewedField)
                                    { <span class="badge bg-success rounded-pill px-2 mt-1 small"><i class="bi bi-check me-1"></i>Đã đánh giá</span> }
                                </div>
                            </div>
                        }
                        </div>
                    }
                    <hr class="my-3">
                    <div class="d-flex flex-column gap-1 text-end">
                        <div class="text-muted small">Tạm tính: <span class="fw-medium">@Model.GetProperty("subTotal").GetDecimal().ToString("N0")₫</span></div>
                        <div class="text-muted small">Phí giao: <span class="fw-medium">@Model.GetProperty("shippingFee").GetDecimal().ToString("N0")₫</span></div>
                        @if (Model.GetProperty("discountAmount").GetDecimal() > 0)
                        { <div class="text-success small">Giảm giá: <span class="fw-medium">-@Model.GetProperty("discountAmount").GetDecimal().ToString("N0")₫</span></div> }
                        <div class="fw-bold fs-5">Tổng cộng: <span class="text-primary">@Model.GetProperty("totalAmount").GetDecimal().ToString("N0")₫</span></div>
                    </div>
                </div>
            </div>

            @* Status history *@
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-clock-history me-2 text-primary"></i>Lịch sử trạng thái</h5>
                    @if (history.ValueKind == JsonValueKind.Array)
                    {
                        <div class="d-flex flex-column gap-3">
                        @foreach (var hh in history.EnumerateArray())
                        {
                            var hStatus = hh.GetProperty("status").GetString() ?? "";
                            var hNote   = hh.TryGetProperty("note", out var hn) && hn.ValueKind != JsonValueKind.Null ? hn.GetString() : null;
                            var hAt     = hh.GetProperty("changedAt").GetDateTime();
                            <div class="d-flex gap-3 align-items-start">
                                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;margin-top:2px">
                                    <i class="bi bi-check text-white small"></i>
                                </div>
                                <div>
                                    <div class="fw-medium">@(statusVi.GetValueOrDefault(hStatus, hStatus))</div>
                                    @if (!string.IsNullOrEmpty(hNote)){<div class="text-muted small">@hNote</div>}
                                    <div class="text-muted small">@hAt.ToString("HH:mm dd/MM/yyyy")</div>
                                </div>
                            </div>
                        }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            @* Shipping info *@
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2 text-primary"></i>Địa chỉ giao hàng</h5>
                    <div class="small d-flex flex-column gap-2">
                        <div><span class="text-muted">Người nhận: </span><strong>@Model.GetProperty("recipientName").GetString()</strong></div>
                        <div><span class="text-muted">Điện thoại: </span>@Model.GetProperty("recipientPhone").GetString()</div>
                        <div><span class="text-muted">Địa chỉ: </span>@Model.GetProperty("shippingAddress").GetString(), @Model.GetProperty("ward").GetString(), @Model.GetProperty("district").GetString(), @Model.GetProperty("province").GetString()</div>
                    </div>
                </div>
            </div>

            @* Payment info *@
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-credit-card me-2 text-primary"></i>Thanh toán</h5>
                    <div class="small d-flex flex-column gap-2">
                        <div><span class="text-muted">Phương thức: </span><strong>@(Model.TryGetProperty("paymentMethod", out var pm) ? pm.GetString() : "—")</strong></div>
                        <div>
                            <span class="text-muted">Trạng thái: </span>
                            <span class="badge rounded-pill @(pStatus=="Paid"?"bg-success":"bg-warning text-dark") px-3">@pStatus</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Carrier tracking *@
            @if (shipment.HasValue)
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-truck me-2 text-primary"></i>Vận chuyển</h5>
                        <div class="small d-flex flex-column gap-2">
                            <div><span class="text-muted">Đơn vị: </span><strong>@shipment.Value.GetProperty("carrierName").GetString()</strong></div>
                            @{var tn = shipment.Value.TryGetProperty("trackingNumber", out var tnn) && tnn.ValueKind != JsonValueKind.Null ? tnn.GetString() : null;}
                            @if (!string.IsNullOrEmpty(tn)){<div><span class="text-muted">Mã vận đơn: </span><code>@tn</code></div>}
                            @{var eta = shipment.Value.TryGetProperty("estimatedDeliveryDate", out var etad) && etad.ValueKind != JsonValueKind.Null ? (DateTime?)etad.GetDateTime() : null;}
                            @if (eta.HasValue){<div><span class="text-muted">Dự kiến giao: </span>@eta.Value.ToString("dd/MM/yyyy")</div>}
                        </div>
                    </div>
                </div>
            }

            @* Actions *@
            @if (canCancel)
            {
                <button class="btn btn-outline-danger w-100 rounded-3" data-bs-toggle="modal" data-bs-target="#cancelModal">
                    <i class="bi bi-x-circle me-2"></i>Hủy đơn hàng
                </button>
            }
        </div>
    </div>
</div>

@* Cancel Modal *@
@if (canCancel)
{
    <div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0"><h5 class="modal-title fw-bold text-danger"><i class="bi bi-x-circle me-2"></i>Hủy đơn hàng</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
                <form asp-action="Cancel" asp-controller="Orders" asp-route-id="@orderId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body p-4">
                        <label class="form-label fw-semibold">Lý do hủy <span class="text-danger">*</span></label>
                        <textarea name="cancelReason" class="form-control rounded-3" rows="3" required maxlength="500" placeholder="Nhập lý do hủy..."></textarea>
                    </div>
                    <div class="modal-footer border-0 justify-content-center gap-2">
                        <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-danger rounded-3 px-4">Xác nhận hủy</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@* Review Modal *@
@if (canReview)
{
    <div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0"><h5 class="modal-title fw-bold"><i class="bi bi-star me-2 text-warning"></i>Đánh giá sản phẩm</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
                <form id="reviewForm" asp-controller="Reviews" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderItemId" id="rvOrderItemId">
                    <input type="hidden" name="orderId" value="@orderId">
                    <div class="modal-body p-4">
                        <div id="rvProductName" class="fw-bold mb-3 text-primary"></div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Đánh giá <span class="text-danger">*</span></label>
                            <div class="d-flex gap-2" id="starRating">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="bi bi-star fs-4 text-muted star-btn" data-star="@s" style="cursor:pointer" onclick="setRating(@s)"></i>
                                }
                            </div>
                            <input type="hidden" name="rating" id="rvRating" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nhận xét</label>
                            <textarea name="comment" class="form-control rounded-3" rows="3" maxlength="1000" placeholder="Chia sẻ cảm nhận của bạn..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 justify-content-center gap-2">
                        <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-warning rounded-3 px-4 text-white">Gửi đánh giá</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
function openReviewModal(itemId, productName) {
    document.getElementById('rvOrderItemId').value = itemId;
    document.getElementById('rvProductName').textContent = productName;
    document.getElementById('rvRating').value = '';
    document.querySelectorAll('.star-btn').forEach(s => {
        s.classList.remove('bi-star-fill','text-warning');
        s.classList.add('bi-star','text-muted');
    });
}
function setRating(val) {
    document.getElementById('rvRating').value = val;
    document.querySelectorAll('.star-btn').forEach(s => {
        const sv = parseInt(s.dataset.star);
        if (sv <= val) { s.classList.add('bi-star-fill','text-warning'); s.classList.remove('bi-star','text-muted'); }
        else           { s.classList.remove('bi-star-fill','text-warning'); s.classList.add('bi-star','text-muted'); }
    });
}
</script>
}
