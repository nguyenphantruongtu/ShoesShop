@model List<ShoesShop.Shared.DTOs.OrderDto>

@{
    ViewData["Title"] = "Lịch sử mua hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-clock-history"></i> Lịch sử đơn hàng của bạn</h2>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info text-center py-4">
            <p class="mb-0">Bạn chưa có đơn hàng nào được đặt.</p>
        </div>
    }
    else
    {
        <div class="table-responsive bg-white p-3 rounded shadow-sm">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Mã Đơn</th>
                        <th>Ngày Đặt</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.OrderId</td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-danger fw-semibold">@item.TotalAmount.ToString("N0") đ</td>
                            <td>
                                @if (item.OrderStatus == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                }
                                else if (item.OrderStatus == "Confirmed")
                                {
                                    <span class="badge bg-primary">Đã xác nhận</span>
                                }
                                else if (item.OrderStatus == "Canceled")
                                {
                                    <span class="badge bg-danger">Đã hủy</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.OrderStatus</span>
                                }
                            </td>
                            <td>
                                @if (item.OrderStatus == "Pending" || item.OrderStatus == "Confirmed")
                                {
                                    <button type="button" class="btn btn-outline-danger btn-sm btn-cancel-order" data-id="@item.OrderId">
                                        <i class="bi bi-x-circle-fill me-1"></i> Hủy đơn
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-light btn-sm text-muted" disabled>Không thể thao tác</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Logic AJAX xử lý nút bấm Hủy Đơn khi được click
            $(document).on('click', '.btn-cancel-order', function () {
                let orderId = $(this).data('id');

                if (confirm(`Bạn có chắc chắn muốn hủy đơn hàng #${orderId} này không?\nHành động này sẽ tự động hoàn trả số lượng sản phẩm vào kho.`)) {
                    let $btn = $(this);
                    $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span> Đang hủy...');

                    $.ajax({
                        url: `https://localhost:7214/api/orders/${orderId}/cancel?userId=1`,
                        type: 'PUT',
                        dataType: 'json',
                        success: function (response) {
                            if (response && response.success) {
                                alert(response.message);
                                window.location.reload();
                            } else {
                                alert("Thất bại: " + response.message);
                                $btn.prop('disabled', false).html('<i class="bi bi-x-circle-fill me-1"></i> Hủy đơn');
                            }
                        },
                        error: function (xhr) {
                            let errorObj = JSON.parse(xhr.responseText || "{}");
                            alert("Lỗi hệ thống: " + (errorObj.message || "Không thể hủy đơn!"));
                            $btn.prop('disabled', false).html('<i class="bi bi-x-circle-fill me-1"></i> Hủy đơn');
                        }
                    });
                }
            });
        });
    </script>
}