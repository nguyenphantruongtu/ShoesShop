@model IEnumerable<ShoesShop.Shared.DTOs.ProductDto>

@{
    ViewData["Title"] = "Trang Chủ - Shoes Shop";
}

<div class="container mt-5">
    <h2 class="text-center mb-4 font-weight-bold text-uppercase">Sản Phẩm Nổi Bật</h2>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger text-center">@ViewBag.ErrorMessage</div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0 rounded">
                        <img src="@(product.ImageUrls.FirstOrDefault() ?? "/images/no-image.png")"
                             class="card-img-top p-3 rounded" alt="@product.ProductName"
                             style="height: 230px; object-fit: cover;">

                        <div class="card-body d-flex flex-column justify-content-between">
                            <h5 class="card-title font-weight-bold text-dark" style="font-size: 1rem;">@product.ProductName</h5>
                            <p class="card-text text-muted small">@product.ShortDescription</p>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div>
                                    @if (product.SalePrice.HasValue)
                                    {
                                        <span class="text-danger font-weight-bold">@product.SalePrice.Value.ToString("#,##0") đ</span>
                                        <br />
                                        <small class="text-muted text-decoration-line-through">@product.BasePrice.ToString("#,##0") đ</small>
                                    }
                                    else
                                    {
                                        <span class="text-dark font-weight-bold">@product.BasePrice.ToString("#,##0") đ</span>
                                    }
                                </div>
                                <a href="/products/@product.ProductId" class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem Chi Tiết</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted">
                <p>Hiện tại chưa có sản phẩm nổi bật nào được kích hoạt.</p>
            </div>
        }
    </div>
</div>