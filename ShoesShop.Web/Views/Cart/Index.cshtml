@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <h2 class="fw-bold mb-4 text-dark"><i class="bi bi-bag-check-fill me-2 text-primary"></i>Giỏ Hàng Của Bạn</h2>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div id="cart-empty" class="text-center py-5 d-none">
                    <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" alt="Giỏ hàng trống" style="width: 120px;" class="mb-3 opacity-75">
                    <h5 class="text-secondary fw-semibold">Giỏ hàng của bạn đang trống trơn!</h5>
                    <p class="text-muted small">Hãy quay lại trang chủ để lựa chọn những đôi giày ưng ý nhất nhé.</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4 py-2 mt-2 text-uppercase fw-bold btn-sm shadow-sm">Tiếp tục mua sắm</a>
                </div>

                <div id="cart-table-wrapper">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light text-secondary small text-uppercase">
                                <tr>
                                    <th scope="col" style="min-width: 280px;">Sản phẩm</th>
                                    <th scope="col" class="text-center">Giá</th>
                                    <th scope="col" class="text-center" style="width: 140px;">Số lượng</th>
                                    <th scope="col" class="text-end">Tổng tiền</th>
                                    <th scope="col" class="text-center">Xóa</th>
                                </tr>
                            </thead>
                            <tbody id="cart-items-list">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 20px; z-index: 10;">
                <h5 class="fw-bold text-dark border-bottom pb-3 mb-3">Tóm tắt đơn hàng</h5>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính:</span>
                    <span id="cart-subtotal" class="fw-semibold text-dark">0 đ</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Phí vận chuyển:</span>
                    <span class="text-success fw-medium">Miễn phí</span>
                </div>

                <hr class="text-muted">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="fw-bold text-dark fs-5">Tổng cộng:</span>
                    <span id="cart-total" class="fw-bold text-danger fs-4">0 đ</span>
                </div>

                <button id="btn-checkout" class="btn btn-dark btn-lg w-100 py-3 rounded-pill text-uppercase fw-bold shadow mb-2">
                    Tiến hành thanh toán <i class="bi bi-arrow-right ms-2"></i>
                </button>
                <a href="/" class="btn btn-outline-secondary w-100 py-2 rounded-pill text-uppercase fw-semibold btn-sm">
                    <i class="bi bi-chevron-left me-1"></i> Tiếp tục mua giày
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // 1. Hàm chính quét và hiển thị toàn bộ sản phẩm từ LocalStorage ra màn hình
            function renderCart() {
                // Rút giỏ hàng ra từ bộ nhớ trình duyệt dưới dạng danh sách
                let cart = JSON.parse(localStorage.getItem('shoes_shop_cart')) || [];

                // Nếu giỏ hàng rỗng hoặc không có phần tử nào
                if (cart.length === 0) {
                    $('#cart-table-wrapper').hide(); // Ẩn bảng sản phẩm đi
                    $('#cart-empty').removeClass('d-none').show(); // Hiện thông báo giỏ hàng trống
                    $('#cart-subtotal').text('0 đ');
                    $('#cart-total').text('0 đ');
                    $('#btn-checkout').prop('disabled', true); // Khóa nút đặt hàng
                    return;
                }

                // Nếu có hàng, mở khóa giao diện bảng và nút thanh toán
                $('#cart-empty').hide();
                $('#cart-table-wrapper').show();
                $('#btn-checkout').prop('disabled', false);

                let htmlList = '';
                let subtotal = 0;

                // Vòng lặp duyệt qua từng món hàng lưu trong LocalStorage để render HTML
                cart.forEach((item, index) => {
                    let itemTotal = item.salePrice * item.quantity;
                    subtotal += itemTotal;

                    htmlList += `
                        <tr class="border-bottom-dashed">
                            <td>
                                <div class="d-flex align-items-center py-2">
                                    <img src="${item.primaryImageUrl}" class="rounded shadow-sm me-3" style="width: 70px; height: 70px; object-fit: cover;" alt="giày">
                                    <div>
                                        <h6 class="fw-bold text-dark mb-1 small">${item.productName}</h6>
                                        <div class="d-flex flex-wrap gap-2 mt-1">
                                            <span class="badge bg-light text-dark border px-2 py-1 small fw-normal">Màu: ${item.colorName}</span>
                                            <span class="badge bg-light text-dark border px-2 py-1 small fw-normal">Size: ${item.sizeName}</span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center fw-medium text-secondary small">
                                ${item.salePrice.toLocaleString('vi-VN')} đ
                            </td>
                            <td class="text-center">
                                <div class="input-group input-group-sm justify-content-center">
                                    <button class="btn btn-outline-secondary btn-minus px-2" data-index="${index}" type="button">-</button>
                                    <input type="text" class="form-control text-center bg-white input-qty" style="max-width: 45px;" value="${item.quantity}" readonly>
                                    <button class="btn btn-outline-secondary btn-plus px-2" data-index="${index}" type="button">+</button>
                                </div>
                            </td>
                            <td class="text-end fw-bold text-dark">
                                ${itemTotal.toLocaleString('vi-VN')} đ
                            </td>
                            <td class="text-center">
                                <button class="btn btn-link text-danger btn-delete p-0 border-0" data-index="${index}" title="Xóa món này">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                </button>
                            </td>
                        </tr>`;
                });

                // Bơm toàn bộ danh sách dòng HTML vào thẻ Tbody
                $('#cart-items-list').html(htmlList);

                // Cập nhật tổng tiền tạm tính và tổng cộng lên form tóm tắt bên phải
                $('#cart-subtotal').text(subtotal.toLocaleString('vi-VN') + ' đ');
                $('#cart-total').text(subtotal.toLocaleString('vi-VN') + ' đ');
            }

            // 2. Kích hoạt chạy hàm hiển thị giỏ hàng ngay khi vừa mở trang lên
            renderCart();

            // 3. Xử lý click NÚT TĂNG SỐ LƯỢNG (+)
            $(document).on('click', '.btn-plus', function () {
                let index = $(this).data('index');
                let cart = JSON.parse(localStorage.getItem('shoes_shop_cart')) || [];

                cart[index].quantity += 1; // Tăng thêm 1 đơn vị số lượng

                localStorage.setItem('shoes_shop_cart', JSON.stringify(cart)); // Lưu đè lại bộ nhớ
                renderCart(); // Tải lại bảng giỏ hàng lập tức
            });

            // 4. Xử lý click NÚT GIẢM SỐ LƯỢNG (-)
            $(document).on('click', '.btn-minus', function () {
                let index = $(this).data('index');
                let cart = JSON.parse(localStorage.getItem('shoes_shop_cart')) || [];

                if (cart[index].quantity > 1) {
                    cart[index].quantity -= 1; // Giảm đi 1 nếu số lượng đang lớn hơn 1
                } else {
                    // Nếu giảm về 0, tiến hành hỏi để xóa món hàng ra khỏi giỏ
                    if(confirm("Bạn có muốn xóa sản phẩm này ra khỏi giỏ hàng không?")) {
                        cart.splice(index, 1);
                    }
                }

                localStorage.setItem('shoes_shop_cart', JSON.stringify(cart));
                renderCart();
            });

            // 5. Xử lý click NÚT THÙNG RÁC XÓA MÓN HÀNG
            $(document).on('click', '.btn-delete', function () {
                let index = $(this).data('index');
                let cart = JSON.parse(localStorage.getItem('shoes_shop_cart')) || [];

                if(confirm("Xác nhận gỡ bỏ sản phẩm này khỏi giỏ hàng?")) {
                    cart.splice(index, 1); // Cắt bỏ món hàng đó ra khỏi mảng danh sách
                    localStorage.setItem('shoes_shop_cart', JSON.stringify(cart));
                    renderCart();
                }
            });

            // 6. Xử lý click NÚT TIẾN HÀNH THANH TOÁN (Hỗ trợ chuẩn bị dữ liệu cho UC tiếp theo)
            $('#btn-checkout').click(function () {
                let cart = JSON.parse(localStorage.getItem('shoes_shop_cart')) || [];
                if (cart.length === 0) return;

                alert("Hệ thống đã ghi nhận giỏ hàng thành công!\nChuyển hướng sang trang điền thông tin Giao hàng & Thanh toán đơn đơn hàng.");

                // Ở bước tiếp theo (UC-06 Đặt hàng), bạn sẽ chuyển hướng sang trang thanh toán:
                window.location.href = '/Checkout';
            });
        });
    </script>
}