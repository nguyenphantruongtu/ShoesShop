@{
    ViewData["Title"] = "Thanh toán thành công — STRIDEX";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int orderId = ViewBag.OrderId ?? 0;
    string paymentStatus = ViewBag.PaymentStatus ?? "Processing";
    string? transactionCode = ViewBag.TransactionCode;
    bool isPaid = paymentStatus == "Paid";
}

<div class="container-xxl px-4 py-5" style="max-width:640px;margin:0 auto">
    <div style="text-align:center;padding:60px 0">

        @if (isPaid)
        {
            <!-- Success -->
            <div style="width:80px;height:80px;background:#000;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px">
                <i class="bi bi-check2" style="color:#fff;font-size:2.4rem"></i>
            </div>
            <h1 style="font-size:1.6rem;font-weight:900;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:12px">
                Thanh toán thành công!
            </h1>
            <p style="color:#555;font-size:0.95rem;margin-bottom:8px">
                Cảm ơn bạn đã mua sắm tại STRIDEX.
            </p>
            <p style="color:#888;font-size:0.85rem;margin-bottom:4px">
                Mã đơn hàng: <strong style="color:#000">#@orderId</strong>
            </p>
            @if (!string.IsNullOrEmpty(transactionCode))
            {
                <p style="color:#888;font-size:0.82rem">
                    Mã giao dịch: <strong style="color:#000">@transactionCode</strong>
                </p>
            }
        }
        else
        {
            <!-- Processing (webhook chưa về) -->
            <div style="width:80px;height:80px;background:#f5c518;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px">
                <i class="bi bi-clock-history" style="color:#000;font-size:2rem"></i>
            </div>
            <h1 style="font-size:1.6rem;font-weight:900;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:12px">
                Đang xử lý thanh toán
            </h1>
            <p style="color:#555;font-size:0.95rem;margin-bottom:8px">
                Hệ thống đang xác nhận thanh toán của bạn. Vui lòng chờ trong giây lát.
            </p>
            <p style="color:#888;font-size:0.85rem">
                Mã đơn hàng: <strong style="color:#000">#@orderId</strong>
            </p>
        }

        <!-- Actions -->
        <div class="d-flex gap-3 justify-content-center mt-5">
            <a href="/Orders/Detail/@orderId" class="btn-black" style="padding:12px 28px">
                <i class="bi bi-receipt me-2"></i>Xem đơn hàng
            </a>
            <a href="/" class="btn-white" style="padding:12px 28px;border:1px solid #000">
                <i class="bi bi-house me-2"></i>Trang chủ
            </a>
        </div>

        <!-- Auto-check sau 5s nếu đang xử lý -->
        @if (!isPaid)
        {
            <p style="color:#aaa;font-size:0.75rem;margin-top:24px" id="auto-check-msg">
                Tự động kiểm tra sau <span id="countdown">5</span>s...
            </p>
        }
    </div>
</div>

@if (!isPaid)
{
    @section Scripts {
    <script>
    let count = 5;
    const el = document.getElementById('countdown');
    const timer = setInterval(() => {
        count--;
        if (el) el.textContent = count;
        if (count <= 0) {
            clearInterval(timer);
            // Reload để re-check status
            window.location.reload();
        }
    }, 1000);
    </script>
    }
}
