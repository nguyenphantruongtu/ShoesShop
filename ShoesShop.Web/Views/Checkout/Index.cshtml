@using System.Text.Json
@{
    ViewData["Title"] = "Thanh toán — STRIDEX";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var savedAddresses = ViewBag.Addresses is JsonElement addr && addr.ValueKind == JsonValueKind.Array
        ? addr.EnumerateArray().ToList()
        : new List<JsonElement>();
    string jwtToken = ViewBag.JwtToken ?? "";
}

<div class="container-xxl px-4 py-5">

    <!-- Header -->
    <div class="mb-5">
        <span class="section-eyebrow">Đặt hàng</span>
        <h1 class="section-title mb-0">Thanh toán</h1>
    </div>

    <!-- Step indicator -->
    <div class="d-flex align-items-center gap-0 mb-5" style="max-width:420px">
        <div class="d-flex align-items-center gap-2">
            <div style="width:28px;height:28px;background:#000;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:800">1</div>
            <span style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em">Giỏ hàng</span>
        </div>
        <div style="flex:1;height:1px;background:#000;margin:0 12px"></div>
        <div class="d-flex align-items-center gap-2">
            <div style="width:28px;height:28px;background:#000;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:800">2</div>
            <span style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em">Thanh toán</span>
        </div>
        <div style="flex:1;height:1px;background:#ddd;margin:0 12px"></div>
        <div class="d-flex align-items-center gap-2">
            <div style="width:28px;height:28px;background:#ddd;color:#888;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:800">3</div>
            <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#888">Hoàn tất</span>
        </div>
    </div>

    <div class="row g-5">

        <!-- LEFT — Form -->
        <div class="col-lg-7">
            <form id="checkout-form" novalidate>

                @if (savedAddresses.Any())
                {
                    <!-- Địa chỉ đã lưu -->
                    <div style="border:1px solid #eee;padding:28px;margin-bottom:24px">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h3 style="font-size:0.82rem;font-weight:800;text-transform:uppercase;letter-spacing:0.12em;margin:0">
                                Địa chỉ đã lưu
                            </h3>
                            <button type="button" id="btn-new-address"
                                    onclick="showNewAddressForm()"
                                    style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;
                                           border:1px solid #000;background:none;color:#000;padding:5px 12px;cursor:pointer">
                                <i class="bi bi-plus me-1"></i>Địa chỉ mới
                            </button>
                        </div>

                        <div id="saved-address-list" style="display:flex;flex-direction:column;gap:10px">
                            @foreach (var a in savedAddresses)
                            {
                                var aid      = a.GetProperty("addressId").GetInt32();
                                var rname    = a.GetProperty("recipientName").GetString() ?? "";
                                var rphone   = a.GetProperty("phone").GetString() ?? "";
                                var street   = a.GetProperty("streetAddress").GetString() ?? "";
                                var ward     = a.TryGetProperty("ward", out var w) ? (w.GetString() ?? "") : "";
                                var district = a.GetProperty("district").GetString() ?? "";
                                var province = a.GetProperty("province").GetString() ?? "";
                                var isDef    = a.GetProperty("isDefault").GetBoolean();

                                <div class="saved-addr-card @(isDef ? "selected" : "")"
                                     data-id="@aid"
                                     data-name="@rname" data-phone="@rphone"
                                     data-street="@street" data-ward="@ward"
                                     data-district="@district" data-province="@province"
                                     onclick="selectAddress(this)"
                                     style="border:@(isDef?"2px solid #000":"1px solid #eee");padding:14px 16px;cursor:pointer;
                                            position:relative;transition:border 0.15s">
                                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px">
                                        <div>
                                            <div style="font-weight:700;font-size:0.85rem">
                                                @rname
                                                @if (isDef)
                                                {
                                                    <span style="font-size:0.65rem;font-weight:700;background:#000;color:#fff;
                                                                 padding:2px 6px;letter-spacing:0.06em;margin-left:8px">MẶC ĐỊNH</span>
                                                }
                                            </div>
                                            <div style="font-size:0.78rem;color:#888;margin-top:2px">@rphone</div>
                                            <div style="font-size:0.78rem;color:#555;margin-top:4px">
                                                @street@(!string.IsNullOrEmpty(ward) ? ", " + ward : ""), @district, @province
                                            </div>
                                        </div>
                                        <div class="addr-check" style="width:20px;height:20px;border-radius:50%;
                                                    border:2px solid @(isDef?"#000":"#ccc");background:@(isDef?"#000":"#fff");
                                                    display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px">
                                            @if (isDef)
                                            {
                                                <i class="bi bi-check" style="color:#fff;font-size:0.7rem"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Shipping info -->
                <div id="new-address-form" style="border:1px solid #eee;padding:28px;margin-bottom:24px;@(savedAddresses.Any() ? "display:none" : "")">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h3 style="font-size:0.82rem;font-weight:800;text-transform:uppercase;letter-spacing:0.12em;margin:0">
                            Thông tin nhận hàng
                        </h3>
                        @if (savedAddresses.Any())
                        {
                            <button type="button" onclick="hideNewAddressForm()"
                                    style="font-size:0.72rem;color:#888;background:none;border:none;cursor:pointer;padding:0">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </button>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label-clean">Họ và tên người nhận <span style="color:#e63946">*</span></label>
                        <input type="text" id="recipientName" class="form-control-clean" placeholder="Nguyễn Văn A" required>
                        <div class="invalid-feedback-clean d-none" id="err-name">Vui lòng nhập họ tên.</div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label-clean">Số điện thoại <span style="color:#e63946">*</span></label>
                            <input type="tel" id="phone" class="form-control-clean" placeholder="0912 345 678" required>
                            <div class="invalid-feedback-clean d-none" id="err-phone">Số điện thoại không hợp lệ.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-clean">Email</label>
                            <input type="email" id="email" class="form-control-clean" placeholder="email@example.com">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-clean">Địa chỉ cụ thể <span style="color:#e63946">*</span></label>
                        <input type="text" id="address" class="form-control-clean" placeholder="Số nhà, tên đường..." required>
                        <div class="invalid-feedback-clean d-none" id="err-address">Vui lòng nhập địa chỉ.</div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label-clean">Tỉnh / Thành phố <span style="color:#e63946">*</span></label>
                            <input type="text" id="province" class="form-control-clean" placeholder="Hồ Chí Minh" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-clean">Quận / Huyện <span style="color:#e63946">*</span></label>
                            <input type="text" id="district" class="form-control-clean" placeholder="Quận 9" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-clean">Phường / Xã</label>
                            <input type="text" id="ward" class="form-control-clean" placeholder="Phường Long Bình">
                        </div>
                    </div>

                    <div>
                        <label class="form-label-clean">Ghi chú</label>
                        <textarea id="note" rows="3" class="form-control-clean" placeholder="Ghi chú thêm về giờ giao, địa điểm..."></textarea>
                    </div>
                </div><!-- end new-address-form -->

                <!-- Payment method -->
                <div style="border:1px solid #eee;padding:28px">
                    <h3 style="font-size:0.82rem;font-weight:800;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:20px">
                        Phương thức thanh toán
                    </h3>

                    <label id="lbl-cod" style="display:flex;align-items:center;gap:12px;padding:14px 16px;border:2px solid #000;cursor:pointer;margin-bottom:10px" onclick="selectPayment(this,'COD')">
                        <input type="radio" name="payment" id="pay-cod" value="COD" checked style="margin:0;accent-color:#000">
                        <div>
                            <div style="font-weight:700;font-size:0.85rem">Thanh toán khi nhận hàng (COD)</div>
                            <div style="font-size:0.75rem;color:#888">Bạn trả tiền mặt khi shipper giao hàng.</div>
                        </div>
                        <i class="bi bi-cash-coin ms-auto" style="font-size:1.3rem;color:#888"></i>
                    </label>

                    <label id="lbl-payos" style="display:flex;align-items:center;gap:12px;padding:14px 16px;border:1px solid #eee;cursor:pointer" onclick="selectPayment(this,'PayOS')">
                        <input type="radio" name="payment" id="pay-payos" value="PayOS" style="margin:0;accent-color:#000">
                        <div>
                            <div style="font-weight:700;font-size:0.85rem">Thanh toán online qua PayOS</div>
                            <div style="font-size:0.75rem;color:#888">QR code / chuyển khoản ngân hàng tức thì.</div>
                        </div>
                        <img src="https://payos.vn/wp-content/uploads/sites/13/2023/07/payos-logo.svg"
                             alt="PayOS" style="height:22px;margin-left:auto"
                             onerror="this.style.display='none'">
                    </label>
                </div>
            </form>
        </div>

        <!-- RIGHT — Order summary -->
        <div class="col-lg-5">
            <div style="border:2px solid #000;padding:28px;position:sticky;top:80px">
                <h3 style="font-size:0.82rem;font-weight:800;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:20px">Đơn hàng của bạn</h3>

                <!-- Items preview -->
                <div id="checkout-items" style="max-height:260px;overflow-y:auto;margin-bottom:16px"></div>

                <!-- Voucher -->
                <div style="margin-bottom:16px;padding-top:12px;border-top:1px solid #eee">
                    <div style="display:flex;gap:8px">
                        <input type="text" id="voucher-code" placeholder="Nhập mã giảm giá"
                               style="flex:1;border:1px solid #ddd;padding:9px 12px;font-size:0.8rem;text-transform:uppercase"
                               onkeydown="if(event.key==='Enter'){event.preventDefault();applyVoucher();}">
                        <button type="button" id="btn-apply-voucher" onclick="applyVoucher()"
                                style="border:1px solid #000;background:#fff;color:#000;padding:0 16px;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;cursor:pointer">
                            Áp dụng
                        </button>
                    </div>
                    <div id="voucher-msg" style="font-size:0.75rem;margin-top:6px"></div>
                </div>

                <div class="d-flex justify-content-between mb-2 pt-2" style="border-top:1px solid #eee">
                    <span style="font-size:0.82rem;color:#666">Tạm tính</span>
                    <span style="font-size:0.82rem;font-weight:700" id="co-subtotal">—</span>
                </div>
                <div class="d-flex justify-content-between mb-2 pb-3" id="co-discount-row" style="display:none;border-bottom:1px solid #eee">
                    <span style="font-size:0.82rem;color:#666">Giảm giá</span>
                    <span style="font-size:0.82rem;font-weight:600;color:#2d6a4f" id="co-discount">—</span>
                </div>
                <div class="d-flex justify-content-between mb-4 pt-2" style="border-top:1px solid #eee">
                    <span style="font-size:1rem;font-weight:800;text-transform:uppercase;letter-spacing:0.04em">Tổng cộng</span>
                    <span style="font-size:1.3rem;font-weight:900" id="co-total">—</span>
                </div>

                <button type="button" id="btn-place-order" class="add-to-cart-btn w-100" onclick="placeOrder()">
                    <i class="bi bi-check2-circle me-2"></i>Xác nhận đặt hàng
                </button>

                <div style="font-size:0.72rem;color:#888;margin-top:12px;text-align:center">
                    <i class="bi bi-shield-check me-1"></i>Thông tin được bảo mật tuyệt đối
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Success modal (COD) -->
<div class="modal fade" id="successModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius:0">
            <div class="modal-body text-center p-5">
                <div style="width:64px;height:64px;background:#000;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px">
                    <i class="bi bi-check2" style="color:#fff;font-size:1.8rem"></i>
                </div>
                <h4 style="font-weight:900;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px">Đặt hàng thành công!</h4>
                <p style="color:#666;font-size:0.88rem;margin-bottom:4px">Cảm ơn bạn đã mua sắm tại STRIDEX.</p>
                <p style="color:#888;font-size:0.82rem">Mã đơn hàng: <strong id="order-id-display" style="color:#000">—</strong></p>
                <div class="d-flex gap-3 justify-content-center mt-4">
                    <a asp-controller="Orders" asp-action="Index" class="btn-black">Xem đơn hàng</a>
                    <a asp-controller="Home" asp-action="Index" class="btn-white" style="border-color:#000">Về trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- PayOS QR Modal -->
<div class="modal fade" id="payosModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
        <div class="modal-content border-0" style="border-radius:0">
            <div class="modal-body p-0">

                <!-- Header -->
                <div style="background:#000;padding:18px 24px;display:flex;align-items:center;justify-content:space-between">
                    <div style="display:flex;align-items:center;gap:10px">
                        <svg width="28" height="28" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#0CC"/><text x="50%" y="60%" text-anchor="middle" fill="#fff" font-size="14" font-weight="bold" font-family="Arial">P</text></svg>
                        <span style="color:#fff;font-weight:700;font-size:1rem;letter-spacing:0.04em">THANH TOÁN QUA PAYOS</span>
                    </div>
                    <button type="button" onclick="cancelPayosPayment()" style="background:none;border:none;color:#fff;opacity:.7;font-size:1.3rem;cursor:pointer;padding:0">&times;</button>
                </div>

                <!-- QR area -->
                <div id="payos-qr-area" style="text-align:center;padding:28px 24px 12px">
                    <div id="payos-qr-loading" style="padding:40px 0">
                        <div class="spinner-border" style="color:#000;width:2.5rem;height:2.5rem"></div>
                        <p style="margin-top:12px;color:#555;font-size:0.85rem">Đang tạo mã QR...</p>
                    </div>
                    <div id="payos-qr-content" style="display:none">
                        <p style="font-size:0.78rem;color:#888;margin-bottom:10px">Quét mã QR bằng app ngân hàng để thanh toán</p>
                        <div style="display:inline-block;padding:10px;border:2px solid #000;border-radius:4px;background:#fff">
                            <div id="payos-qr-canvas" style="width:200px;height:200px"></div>
                        </div>
                        <div style="margin-top:14px;padding:10px 16px;background:#f8f8f8;border-radius:4px">
                            <span style="font-size:0.8rem;color:#666">Tổng tiền</span>
                            <div style="font-size:1.3rem;font-weight:900;color:#000;letter-spacing:0.02em" id="payos-amount-display">—</div>
                        </div>
                    </div>
                </div>

                <!-- Status / Polling -->
                <div id="payos-status-area" style="text-align:center;padding:8px 24px 20px">
                    <div id="payos-waiting" style="display:none">
                        <span class="spinner-border spinner-border-sm" style="color:#555;margin-right:6px"></span>
                        <span style="font-size:0.82rem;color:#555">Đang chờ thanh toán...</span>
                    </div>
                    <div id="payos-paid" style="display:none">
                        <div style="width:48px;height:48px;background:#1a9c3e;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 10px">
                            <i class="bi bi-check2" style="color:#fff;font-size:1.4rem"></i>
                        </div>
                        <p style="font-weight:700;color:#1a9c3e;font-size:1rem;margin-bottom:4px">Thanh toán thành công!</p>
                        <p style="font-size:0.8rem;color:#666">Đang chuyển đến trang xác nhận...</p>
                    </div>
                </div>

                <!-- Footer fallback -->
                <div style="border-top:1px solid #eee;padding:12px 24px;text-align:center">
                    <a id="payos-fallback-link" href="#" target="_blank"
                       style="font-size:0.78rem;color:#666;text-decoration:none">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Mở trang thanh toán PayOS
                    </a>
                    <span style="color:#ddd;margin:0 8px">|</span>
                    <button type="button" onclick="cancelPayosPayment()"
                            style="font-size:0.78rem;color:#999;background:none;border:none;cursor:pointer;padding:0">
                        Huỷ thanh toán
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
const API_BASE = 'https://localhost:7214';
const JWT_TOKEN = '@Html.Raw(jwtToken)';
let cart = [];
let usingNewAddress = @(savedAddresses.Any() ? "false" : "true");

// Trích thông điệp lỗi rõ ràng từ response API (hỗ trợ cả ApiResponse.message lẫn ModelState.errors)
function extractApiError(data, fallback) {
    if (!data) return fallback;
    if (data.message) return data.message;
    if (data.Message) return data.Message;
    if (data.errors) {
        const msgs = Object.values(data.errors).flat();
        if (msgs.length) return msgs.join(' ');
    }
    if (data.title) return data.title;
    return fallback;
}

$(document).ready(function() {
    cart = JSON.parse(localStorage.getItem('shoes_shop_cart')) || [];
    if (!cart.length) { window.location.href = '/Cart'; return; }
    renderItems();
    renderSummary();

    // Nếu có địa chỉ đã lưu, tự điền địa chỉ đang được chọn vào các hidden fields
    const defaultCard = document.querySelector('.saved-addr-card.selected');
    if (defaultCard) fillFromCard(defaultCard);

    // Khôi phục + validate lại voucher đã áp từ trang Giỏ hàng (nếu có)
    const savedVoucherCode = sessionStorage.getItem('cart_voucher_code');
    if (savedVoucherCode) {
        document.getElementById('voucher-code').value = savedVoucherCode;
        applyVoucher();
    }
});

function selectAddress(card) {
    document.querySelectorAll('.saved-addr-card').forEach(c => {
        c.classList.remove('selected');
        c.style.border = '1px solid #eee';
        c.querySelector('.addr-check').style.background = '#fff';
        c.querySelector('.addr-check').style.borderColor = '#ccc';
        c.querySelector('.addr-check').innerHTML = '';
    });
    card.classList.add('selected');
    card.style.border = '2px solid #000';
    card.querySelector('.addr-check').style.background = '#000';
    card.querySelector('.addr-check').style.borderColor = '#000';
    card.querySelector('.addr-check').innerHTML = '<i class="bi bi-check" style="color:#fff;font-size:0.7rem"></i>';
    fillFromCard(card);
    usingNewAddress = false;
}

function fillFromCard(card) {
    document.getElementById('recipientName').value = card.dataset.name || '';
    document.getElementById('phone').value         = card.dataset.phone || '';
    document.getElementById('address').value       = card.dataset.street || '';
    document.getElementById('ward').value          = card.dataset.ward || '';
    document.getElementById('district').value      = card.dataset.district || '';
    document.getElementById('province').value      = card.dataset.province || '';
}

function showNewAddressForm() {
    document.getElementById('new-address-form').style.display = '';
    ['recipientName','phone','address','ward','district','province'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
    document.querySelectorAll('.saved-addr-card').forEach(c => {
        c.classList.remove('selected');
        c.style.border = '1px solid #eee';
        c.querySelector('.addr-check').style.background = '#fff';
        c.querySelector('.addr-check').style.borderColor = '#ccc';
        c.querySelector('.addr-check').innerHTML = '';
    });
    usingNewAddress = true;
    document.getElementById('new-address-form').scrollIntoView({behavior:'smooth'});
}

function hideNewAddressForm() {
    document.getElementById('new-address-form').style.display = 'none';
    const defaultCard = document.querySelector('.saved-addr-card') ;
    if (defaultCard) selectAddress(defaultCard);
    usingNewAddress = false;
}

function renderItems() {
    let html = '';
    cart.forEach(item => {
        html += `
        <div style="display:flex;gap:12px;align-items:center;padding:8px 0;border-bottom:1px solid #f3f3f3">
            <img src="${item.primaryImageUrl||'https://placehold.co/48x48/f3f3f3/888?text=?'}"
                 style="width:48px;height:48px;object-fit:cover;flex-shrink:0"
                 onerror="this.src='https://placehold.co/48x48/f3f3f3/888?text=?'">
            <div style="flex:1;min-width:0">
                <div style="font-weight:700;font-size:0.8rem;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${item.productName}</div>
                <div style="font-size:0.72rem;color:#888">${item.colorName||''} ${item.sizeName?'/ '+item.sizeName:''} × ${item.quantity}</div>
            </div>
            <div style="font-weight:700;font-size:0.82rem;flex-shrink:0">${(item.salePrice*item.quantity).toLocaleString('vi-VN')}₫</div>
        </div>`;
    });
    document.getElementById('checkout-items').innerHTML = html;
}

// Voucher đã áp dụng thành công (null nếu chưa áp) — server sẽ validate lại lúc đặt hàng.
let appliedVoucher = null;

function getSubtotal() {
    return parseFloat(sessionStorage.getItem('cart_subtotal')) ||
           cart.reduce((s,i)=>s+(i.salePrice||0)*i.quantity, 0);
}

function renderSummary() {
    const subtotal = getSubtotal();
    const discount = appliedVoucher ? appliedVoucher.discountAmount : 0;
    const total    = subtotal - discount;

    document.getElementById('co-subtotal').textContent = subtotal.toLocaleString('vi-VN') + '₫';

    const discountRow = document.getElementById('co-discount-row');
    if (discount > 0) {
        discountRow.style.display = '';
        document.getElementById('co-discount').textContent = '-' + discount.toLocaleString('vi-VN') + '₫';
    } else {
        discountRow.style.display = 'none';
    }

    document.getElementById('co-total').textContent = total.toLocaleString('vi-VN') + '₫';
}

async function applyVoucher() {
    const codeInput = document.getElementById('voucher-code');
    const msgEl      = document.getElementById('voucher-msg');
    const code       = codeInput.value.trim();
    if (!code) { msgEl.style.color = '#e63946'; msgEl.textContent = 'Vui lòng nhập mã voucher.'; return; }

    const btn = document.getElementById('btn-apply-voucher');
    btn.disabled = true;
    msgEl.style.color = '#888';
    msgEl.textContent = 'Đang kiểm tra...';

    try {
        const res = await fetch(API_BASE + '/api/vouchers/apply', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(JWT_TOKEN ? { 'Authorization': 'Bearer ' + JWT_TOKEN } : {})
            },
            body: JSON.stringify({ Code: code, SubTotal: getSubtotal() })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data?.message || 'Mã voucher không hợp lệ.');

        const d = data?.data || data?.Data || {};
        appliedVoucher = {
            code: d.code || d.Code || code,
            discountAmount: d.discountAmount ?? d.DiscountAmount ?? 0
        };
        sessionStorage.setItem('cart_voucher_code', appliedVoucher.code);
        msgEl.style.color = '#2d6a4f';
        msgEl.textContent = `Đã áp dụng mã "${appliedVoucher.code}" — giảm ${appliedVoucher.discountAmount.toLocaleString('vi-VN')}₫.`;
        renderSummary();
    } catch (err) {
        appliedVoucher = null;
        sessionStorage.removeItem('cart_voucher_code');
        msgEl.style.color = '#e63946';
        msgEl.textContent = err.message || 'Không áp dụng được mã này.';
        renderSummary();
    } finally {
        btn.disabled = false;
    }
}

function selectPayment(label, value) {
    ['lbl-cod','lbl-payos'].forEach(id => {
        const el = document.getElementById(id);
        if (el) { el.style.border = '1px solid #eee'; }
    });
    label.style.border = '2px solid #000';
}

async function placeOrder() {
    let name, phone, address, province, district, ward, note;

    if (!usingNewAddress) {
        // Đọc từ card đã chọn
        const card = document.querySelector('.saved-addr-card.selected');
        if (!card) { alert('Vui lòng chọn địa chỉ giao hàng.'); return; }
        name     = card.dataset.name     || '';
        phone    = card.dataset.phone    || '';
        address  = card.dataset.street   || '';
        province = card.dataset.province || '';
        district = card.dataset.district || '';
        ward     = card.dataset.ward     || '';
        note     = document.getElementById('note') ? document.getElementById('note').value.trim() : '';

        // Địa chỉ đã lưu có thể chứa dữ liệu cũ (vd. SĐT không đủ 10 số) — kiểm tra trước khi gửi
        if (!/^0\d{9}$/.test(phone)) {
            alert('Số điện thoại của địa chỉ này không hợp lệ (phải gồm 10 chữ số bắt đầu bằng 0). Vui lòng cập nhật lại địa chỉ trong trang tài khoản.');
            return;
        }
    } else {
        // Đọc từ form nhập tay + validate
        name     = document.getElementById('recipientName').value.trim();
        phone    = document.getElementById('phone').value.trim();
        address  = document.getElementById('address').value.trim();
        province = document.getElementById('province').value.trim();
        district = document.getElementById('district').value.trim();
        ward     = document.getElementById('ward').value.trim();
        note     = document.getElementById('note').value.trim();

        let valid = true;
        [['err-name', name], ['err-phone', phone], ['err-address', address]].forEach(([id, val]) => {
            const el = document.getElementById(id);
            if (!val) { el.classList.remove('d-none'); valid = false; }
            else        el.classList.add('d-none');
        });
        if (!valid) return;
        if (!/^0\d{9}$/.test(phone)) {
            document.getElementById('err-phone').classList.remove('d-none');
            document.getElementById('err-phone').textContent = 'Số điện thoại phải có 10 chữ số bắt đầu bằng 0.';
            return;
        }
    }

    const paymentMethod = document.querySelector('input[name="payment"]:checked')?.value || 'COD';
    const subtotal = getSubtotal();
    const discount = appliedVoucher ? appliedVoucher.discountAmount : 0;
    const total    = subtotal - discount;

    const btn = document.getElementById('btn-place-order');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';

    const payload = {
        RecipientName:   name,
        RecipientPhone:  phone,
        ShippingAddress: address,
        Province:        province || 'Chưa phân loại',
        District:        district || 'Chưa phân loại',
        Ward:            ward     || '',
        Note:            note,
        PaymentMethod:   paymentMethod,
        VoucherCode:     appliedVoucher ? appliedVoucher.code : null,
        // Các trường số tiền dưới đây chỉ để hiển thị — server tự tính lại từ DB, không tin giá trị này.
        SubTotal:        subtotal,
        DiscountAmount:  discount,
        TotalAmount:     total,
        Items: cart.map(item => ({
            VariantId:   parseInt(item.variantId || 1),
            ProductName: item.productName,
            SizeValue:   item.sizeName || 'Mặc định',
            ColorName:   item.colorName || 'Mặc định',
            Quantity:    item.quantity,
            UnitPrice:   item.salePrice || 0
        }))
    };

    try {
        // Bước 1: Tạo đơn hàng
        const orderRes = await fetch(API_BASE + '/api/orders', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(JWT_TOKEN ? { 'Authorization': 'Bearer ' + JWT_TOKEN } : {})
            },
            body: JSON.stringify(payload)
        });
        const orderData = await orderRes.json();
        if (!orderRes.ok) throw new Error(extractApiError(orderData, 'Đặt hàng thất bại.'));

        const orderId = orderData?.data || orderData?.Data;
        localStorage.removeItem('shoes_shop_cart');
        const badge = document.getElementById('cart-count');
        if (badge) { badge.textContent = '0'; badge.style.display = 'none'; }

        if (paymentMethod === 'PayOS') {
            // Bước 2: Tạo PayOS payment link
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo link thanh toán...';
            const linkRes = await fetch(API_BASE + '/api/payments/create-link', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    ...(JWT_TOKEN ? { 'Authorization': 'Bearer ' + JWT_TOKEN } : {})
                },
                body: JSON.stringify({ orderId: orderId })
            });
            const linkData = await linkRes.json();
            if (!linkRes.ok) throw new Error(extractApiError(linkData, 'Không tạo được link thanh toán.'));

            const d = linkData?.data || linkData?.Data || {};
            const checkoutUrl = d.checkoutUrl || d.CheckoutUrl;
            const qrCode = d.qrCode || d.QrCode;
            if (!checkoutUrl) throw new Error('Không nhận được link thanh toán từ PayOS.');

            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check2-circle me-2"></i>Xác nhận đặt hàng';

            // Bước 3: Hiển thị QR modal + bắt đầu poll
            showPayosModal(orderId, checkoutUrl, qrCode, total);
        } else {
            // COD: hiện modal thành công
            document.getElementById('order-id-display').textContent = '#' + orderId;
            new bootstrap.Modal(document.getElementById('successModal')).show();
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check2-circle me-2"></i>Xác nhận đặt hàng';
        }
    } catch (err) {
        console.error('Error:', err);
        alert('Lỗi: ' + (err.message || 'Lỗi hệ thống'));
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check2-circle me-2"></i>Xác nhận đặt hàng';
    }
}

function tryParseError(text) {
    try { return JSON.parse(text)?.message || JSON.parse(text)?.title || text; }
    catch { return text || 'Lỗi hệ thống'; }
}

// ── PayOS QR Modal ────────────────────────────────────────────────────────────
let _payosPollTimer = null;
let _payosOrderId   = null;

function showPayosModal(orderId, checkoutUrl, qrCode, totalAmount) {
    _payosOrderId = orderId;

    // Reset UI
    document.getElementById('payos-qr-loading').style.display = 'block';
    document.getElementById('payos-qr-content').style.display = 'none';
    document.getElementById('payos-waiting').style.display = 'none';
    document.getElementById('payos-paid').style.display = 'none';
    document.getElementById('payos-fallback-link').href = checkoutUrl || '#';
    document.getElementById('payos-amount-display').textContent = totalAmount
        ? totalAmount.toLocaleString('vi-VN') + '₫' : '—';

    // Mở modal
    const modal = new bootstrap.Modal(document.getElementById('payosModal'));
    modal.show();

    // Generate QR: ưu tiên dùng qrCode (VietQR EMVCo data) từ PayOS,
    // fallback sang checkoutUrl nếu qrCode trống
    const qrData = (qrCode && qrCode.length > 10) ? qrCode : checkoutUrl;
    const canvas = document.getElementById('payos-qr-canvas');
    canvas.innerHTML = '';
    new QRCode(canvas, {
        text:          qrData,
        width:         200,
        height:        200,
        colorDark:     '#000000',
        colorLight:    '#ffffff',
        correctLevel:  QRCode.CorrectLevel.M
    });
    document.getElementById('payos-qr-loading').style.display = 'none';
    document.getElementById('payos-qr-content').style.display  = 'block';
    document.getElementById('payos-waiting').style.display     = 'block';

    // Poll mỗi 3 giây
    _payosPollTimer = setInterval(() => pollPaymentStatus(orderId), 3000);
}

async function pollPaymentStatus(orderId) {
    try {
        const res = await fetch(API_BASE + '/api/payments/status/' + orderId, {
            headers: JWT_TOKEN ? { 'Authorization': 'Bearer ' + JWT_TOKEN } : {}
        });
        if (!res.ok) return;
        const data = await res.json();
        const status = data?.data?.paymentStatus || data?.data?.PaymentStatus;
        if (status === 'Paid') {
            clearInterval(_payosPollTimer);
            document.getElementById('payos-waiting').style.display = 'none';
            document.getElementById('payos-paid').style.display = 'block';
            // Redirect sau 1.5 giây
            setTimeout(() => {
                window.location.href = '/Payment/Success?orderId=' + orderId;
            }, 1500);
        }
    } catch { /* bỏ qua lỗi mạng tạm thời */ }
}

function cancelPayosPayment() {
    clearInterval(_payosPollTimer);
    const modal = bootstrap.Modal.getInstance(document.getElementById('payosModal'));
    if (modal) modal.hide();
    if (_payosOrderId) {
        window.location.href = '/Payment/Cancel?orderId=' + _payosOrderId;
    }
}
