@model ShoesShop.Shared.DTOs.DashboardDto

@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .custom-card {
        border: none;
        border-radius: 12px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .custom-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.08) !important;
    }
    .icon-shape {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
    }
</style>

<div class="container mt-4 pb-5">
    <div class="d-flex align-items-center mb-4">
        <h3 class="fw-bold text-dark m-0">Tổng Quan Hệ Thống</h3>
    </div>

    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_Sidebar")
        </div>
        <div class="col-md-9">

            <h5 class="text-muted fw-semibold mb-3"><i class="bi bi-currency-dollar me-2"></i>Thống kê doanh thu</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card custom-card shadow-sm p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted text-uppercase fs-7 fw-bold mb-1">Hôm nay</h6>
                                <h3 class="fw-bold text-success m-0">@Model.RevenueToday.ToString("#,##0") đ</h3>
                            </div>
                            <div class="icon-shape bg-success bg-opacity-10 text-success">
                                <i class="bi bi-wallet2 fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card custom-card shadow-sm p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted text-uppercase fs-7 fw-bold mb-1">Tuần này</h6>
                                <h3 class="fw-bold text-success m-0">@Model.RevenueWeek.ToString("#,##0") đ</h3>
                            </div>
                            <div class="icon-shape bg-success bg-opacity-10 text-success">
                                <i class="bi bi-graph-up-arrow fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card custom-card shadow-sm p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted text-uppercase fs-7 fw-bold mb-1">Tháng này</h6>
                                <h3 class="fw-bold text-success m-0">@Model.RevenueMonth.ToString("#,##0") đ</h3>
                            </div>
                            <div class="icon-shape bg-success bg-opacity-10 text-success">
                                <i class="bi bi-cash-stack fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="text-muted fw-semibold mb-3"><i class="bi bi-bag-check me-2"></i>Thống kê đơn hàng</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card custom-card shadow-sm p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted text-uppercase fs-7 fw-bold mb-1">Đơn hôm nay</h6>
                                <h3 class="fw-bold text-primary m-0">@Model.OrdersToday</h3>
                            </div>
                            <div class="icon-shape bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-cart3 fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card custom-card shadow-sm p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted text-uppercase fs-7 fw-bold mb-1">Đơn tuần này</h6>
                                <h3 class="fw-bold text-primary m-0">@Model.OrdersWeek</h3>
                            </div>
                            <div class="icon-shape bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-cart-check fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card custom-card shadow-sm p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted text-uppercase fs-7 fw-bold mb-1">Đơn tháng này</h6>
                                <h3 class="fw-bold text-primary m-0">@Model.OrdersMonth</h3>
                            </div>
                            <div class="icon-shape bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-boxes fs-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="card custom-card shadow-sm p-4 bg-white">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-shape bg-info bg-opacity-10 text-info me-3">
                                <i class="bi bi-activity fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold m-0">Xu Hướng Doanh Thu 7 Ngày Qua</h5>
                                <small class="text-muted">Cập nhật dữ liệu thời gian thực</small>
                            </div>
                        </div>
                        <div style="position: relative; height:300px; width:100%;">
                            <canvas id="revenueChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function(){
            var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last7DaysLabels));
            var data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last7DaysRevenue));

            var ctx = document.getElementById('revenueChart').getContext('2d');

            // Tạo hiệu ứng đổ màu Gradient mượt mà cho biểu đồ
            var gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(40, 167, 69, 0.25)');
            gradient.addColorStop(1, 'rgba(40, 167, 69, 0.0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (đ)',
                        data: data,
                        borderColor: '#28a745',
                        borderWidth: 3,
                        pointBackgroundColor: '#28a745',
                        pointHoverRadius: 6,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.35
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false // Ẩn label thừa vì tiêu đề thẻ đã rõ nghĩa
                        }
                    },
                    scales: {
                        x: {
                            grid: {
                                display: false // Ẩn lưới trục X cho gọn gàng
                            }
                        },
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)' // Làm mờ đường lưới trục Y
                            }
                        }
                    }
                }
            });
        })();
    </script>
}